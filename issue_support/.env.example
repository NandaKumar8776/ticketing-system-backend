# ============================================
# Issue Support RAG System - Environment Config
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Demo Auth (optional) ---
# If set, all endpoints except /health require: X-API-Key: <value>
# Leave empty to disable auth (local dev)
DEMO_API_KEY= secret_key_here

# --- LangChain (optional tracing) ---
LANGCHAIN_API_KEY=lsv2_pt_your_langchain_key_here
LANGCHAIN_PROJECT_NAME=Issue-Support-RAG

# --- Prompt Directories (relative to project root) ---
LLM_PROMPT_DIR=prompts/llm_prompt.txt
EVALUATOR_LLM_PROMPT_DIR=prompts/evaluator_llm_prompt.txt
RAG_PROMPT_DIR=prompts/rag_prompt.txt
ROUTER_PROMPT_DIR=prompts/router_prompt.txt
GUARDRAILS_PROMPT_DIR=prompts/guardrails_llm_prompt.txt

# --- Data ---
# FILE_DIR: fallback for local dev only (GCS takes priority when GCS_BUCKET is set)
FILE_DIR=data/PC_trouble-shooting.pdf
UPLOAD_DIR=data/uploads

# --- GCS Document Store ---
# Set to your GCS bucket name to enable persistent document storage.
# Uploaded PDFs are stored under gs://<GCS_BUCKET>/documents/ and
# automatically downloaded at container startup.
# Leave empty to use FILE_DIR fallback (local dev).
GCS_BUCKET=ticket-support-01-dvc

# --- Langfuse Observability ---
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# --- RAG Settings ---
RAG_DEBUG=false
RAG_SCORE_THRESHOLD=0.75

# --- Milvus Vector DB ---
# Local (Docker Compose):   MILVUS_URI=http://localhost:19530
# Milvus Lite / Zilliz:     APP_MILVUS_URI=./milvus_demo.db  (or https://... for Zilliz)
# Note: use APP_MILVUS_URI for non-HTTP URIs — pymilvus reads MILVUS_URI at
# import time and rejects file paths. APP_MILVUS_URI takes priority in our code.
MILVUS_URI=http://localhost:19530
# APP_MILVUS_URI=./milvus_demo.db
MILVUS_DB_NAME=milvus_assignment_test

# --- Zilliz Cloud (only required when MILVUS_URI is an https:// endpoint) ---
ZILLIZ_API_KEY=your_zilliz_api_key_here

# --- Frontend ---
API_URL=http://localhost:8000
